# ============================================================
# Auto-Apply: Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit the .env file to version control.
# All variables match Settings fields in backend/app/config.py.
# ============================================================

# --- Application ---
# Display name surfaced in /docs and logs.
APP_NAME=Auto-Apply API
# Environment switch: development | staging | production.
# In production, the app refuses to start with a default or <32-char SECRET_KEY.
ENVIRONMENT=development

# --- Database (PostgreSQL) ---
# Async SQLAlchemy DSN for the FastAPI backend.
DATABASE_URL=postgresql+asyncpg://autoapply:changeme@localhost:5432/autoapply_db
# Plain Postgres credentials consumed by the docker-compose `db` service.
POSTGRES_USER=autoapply
POSTGRES_PASSWORD=changeme
POSTGRES_DB=autoapply_db

# --- Authentication (JWT) ---
# HMAC secret for signing JWTs. MUST be replaced (>=32 chars) in production.
SECRET_KEY=your-secret-key-change-in-production
# Access-token lifetime in minutes (default 60).
ACCESS_TOKEN_EXPIRE_MINUTES=60
# JWT signing algorithm. HS256 is the only supported value today.
ALGORITHM=HS256

# --- LLM Provider (Google Gemini via OpenAI-compat endpoint) ---
# Paste a Gemini API key from https://aistudio.google.com/app/apikey .
# The env-var name is kept as OPENAI_API_KEY for backward-compat with
# existing deployments; the code points at Gemini's OpenAI-compat URL.
OPENAI_API_KEY=your-gemini-api-key-here

# --- Job API (Adzuna) ---
# Register a free developer account at https://developer.adzuna.com/
# (free tier: 250 requests/month).
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key

# --- File Storage ---
# Local directory used by ResumeService for uploaded CVs.
UPLOAD_DIR=./uploads
# Per-user resume quota; ResumeService raises HTTP 413 once exceeded.
MAX_RESUMES_PER_USER=5
# Future S3-compatible storage:
# S3_BUCKET_NAME=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT_URL=

# --- CORS ---
# JSON array of frontend origins allowed by the FastAPI CORS middleware.
CORS_ORIGINS=["http://localhost:5173"]

# --- Job Scanner Scheduler ---
# How often the APScheduler cron sweeps every opted-in user (hours).
JOB_SCAN_INTERVAL_HOURS=24
# Manual /jobs/scan rate limit per user (hours between calls).
JOB_SCAN_RATE_LIMIT_HOURS=1

# --- Prompt Cache ---
# Optional Redis DSN for the shared prompt cache. Empty string falls back
# to an in-memory LRU per backend process.
REDIS_URL=
# Master switch for the LLM prompt cache (set to false to bypass entirely).
PROMPT_CACHE_ENABLED=true
# Cache TTL in seconds (default 86400 = 24h).
PROMPT_CACHE_TTL_SECONDS=86400
